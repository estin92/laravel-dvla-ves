{
    "name": "estin92/laravel-dvla-ves",
    "description": "DVLA Vehicle Enquiry Service (VES) API connector for Laravel. Returns typed vehicle data straight from the DVLA VES endpoint.",
    "keywords": ["laravel", "dvla", "ves", "vehicle-enquiry", "vehicle", "dvsa", "uk"],
    "license": "MIT",
    "authors": [
        {
            "name": "Ian Austin",
            "homepage": "https://github.com/estin92"
        }
    ],
    "autoload": {
        "psr-4": {
            "Estin92\\DvlaVes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Estin92\\DvlaVes\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "nesbot/carbon": "^2.0|^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Estin92\\DvlaVes\\DvlaVesServiceProvider"
            ],
            "aliases": {
                "DvlaVes": "Estin92\\DvlaVes\\Facades\\DvlaVes"
            }
        }
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
