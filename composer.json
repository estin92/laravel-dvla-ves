{
    "name": "estin92/laravel-dvla-ves",
    "description": "Look up UK vehicle tax, MOT, fuel type and emissions by registration number in Laravel via the official DVLA Vehicle Enquiry Service (VES) API. Returns a typed, immutable VehicleData object.",
    "keywords": ["laravel", "php", "dvla", "ves", "vehicle-enquiry", "vehicle", "registration", "mot", "vehicle-tax", "uk", "dvla-api"],
    "license": "MIT",
    "authors": [
        {
            "name": "Ian Austin",
            "homepage": "https://github.com/estin92"
        }
    ],
    "autoload": {
        "psr-4": {
            "Estin92\\DvlaVes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Estin92\\DvlaVes\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "nesbot/carbon": "^2.0|^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Estin92\\DvlaVes\\DvlaVesServiceProvider"
            ],
            "aliases": {
                "DvlaVes": "Estin92\\DvlaVes\\Facades\\DvlaVes"
            }
        }
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
